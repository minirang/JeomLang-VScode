{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "JeomLang",
  "scopeName": "source.jeom",
  "fileTypes": [
    "jeom"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#control"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#io"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#types"
    },
    {
      "include": "#stack"
    },
    {
      "include": "#collections"
    },
    {
      "include": "#filesystem"
    },
    {
      "include": "#system"
    },
    {
      "include": "#names"
    },
    {
      "include": "#invalid"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.jeom",
          "match": "◘.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.jeom",
          "begin": "●",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.jeom"
            }
          },
          "end": "●",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.jeom"
            }
          },
          "patterns": [
            {
              "name": "constant.character.byte.binary.jeom",
              "match": "[.·]{8}"
            },
            {
              "name": "punctuation.separator.byte.jeom",
              "match": "‧"
            },
            {
              "name": "invalid.illegal.string-byte.jeom",
              "match": "[^\\s.·‧●]+|[.·]{1,7}(?![.·])"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])•[.·]*•(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        },
        {
          "name": "constant.numeric.float.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])•[.·]*‥[.·]*•(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        }
      ]
    },
    "control": {
      "patterns": [
        {
          "name": "keyword.control.main.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])•·(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        },
        {
          "name": "keyword.control.conditional.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])(?:…‥|…·|…)(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        },
        {
          "name": "keyword.control.loop.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])(?:‥∘∘|‥∘|‥‥|‥)(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        },
        {
          "name": "keyword.control.exception.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])(?:‥·⦁|‥·˙|‥··|‥·)(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        },
        {
          "name": "punctuation.section.block.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])(?:⋮⋮|⋮)(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "storage.modifier.variable.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])(?:∘∘∘|∘∘|∘⋅|∘)(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        },
        {
          "name": "storage.type.function.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])(?:˙∘∘|˙∘|˙⦁|˙⋅|˙˙˙|˙˙|˙)(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        }
      ]
    },
    "io": {
      "patterns": [
        {
          "name": "support.function.io.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])(?:·˙˙|·˙|·∘|·⦁|··|·)(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])(?:⋅∘∘∘|⋅∘∘|⋅∘|⋅⋅⋅|⋅⋅|⋅)(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        },
        {
          "name": "keyword.operator.logical.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])(?:⋅⦁⦁⦁|⋅⦁⦁|⋅⦁∘|⋅⦁)(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        },
        {
          "name": "keyword.operator.comparison.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])(?:⋅‧∘∘∘|⋅‧∘∘|⋅‧∘|⋅‧‧‧|⋅‧‧|⋅‧)(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.function.conversion.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])(?:⸳⸳⸳|⸳⸳|⸳∘|⸳⦁|⸳⋅|⸳‧|⸳)(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        }
      ]
    },
    "stack": {
      "patterns": [
        {
          "name": "support.function.stack.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])(?:⦁∘⦁|⦁⦁⦁|⦁⦁|⦁∘|⦁)(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        }
      ]
    },
    "collections": {
      "patterns": [
        {
          "name": "support.function.collection.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])(?:◦⋅⋅⋅|◦‧‧‧|◦∘∘|◦⦁⦁|◦◦◦|◦⋅⋅|◦‧‧|◦∘|◦⦁|◦⋅|◦‧|◦◦|◦)(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        }
      ]
    },
    "filesystem": {
      "patterns": [
        {
          "name": "support.function.filesystem.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])(?:⋯·⦁⦁|⋯·⦁|⋯·˙|⋯⋯⋯|⋯∘∘|⋯⦁⦁|⋯⋯|⋯∘|⋯⦁|⋯⋅|⋯‧|⋯·|⋯)(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        }
      ]
    },
    "system": {
      "patterns": [
        {
          "name": "support.function.system.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])(?:⋮‧‧‧|⋮··|⋮·∘|⋮·⦁|⋮∘∘|⋮‧‧|⋮·|⋮∘|⋮⦁|⋮⋅|⋮‧)(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        }
      ]
    },
    "names": {
      "patterns": [
        {
          "name": "entity.name.variable.jeom",
          "match": "(?<![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])[.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘]+(?![.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘])"
        }
      ]
    },
    "invalid": {
      "patterns": [
        {
          "name": "invalid.illegal.character.jeom",
          "match": "[^\\s.·˙•․‥…‧∘⋅●◦⦁⸳⋮⋯◘]+"
        }
      ]
    }
  }
}
